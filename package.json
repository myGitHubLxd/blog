{
  "name": "bestswifter-blog",
  "version": "1.0.0",
  "description": "High-performance static blog with optimized build system",
  "main": "index.js",
  "scripts": {
    "build": "npm run build:clean && npm run build:site && npm run build:optimize",
    "build:clean": "rimraf dist",
    "build:site": "vite build",
    "build:optimize": "npm run optimize:images && npm run optimize:compress",
    "optimize:images": "node scripts/optimize-images.js",
    "optimize:compress": "node scripts/compress-assets.js",
    "dev": "vite",
    "preview": "vite preview",
    "analyze": "npm run build && npx vite-bundle-analyzer dist",
    "lighthouse": "node scripts/lighthouse-audit.js"
  },
  "devDependencies": {
    "vite": "^5.0.0",
    "@vitejs/plugin-static-copy": "^1.0.0",
    "vite-plugin-pwa": "^0.17.0",
    "vite-plugin-compress": "^1.1.0",
    "markdown-it": "^14.0.0",
    "markdown-it-anchor": "^8.6.0",
    "markdown-it-table-of-contents": "^0.6.0",
    "markdown-it-prism": "^2.3.0",
    "sharp": "^0.33.0",
    "imagemin": "^8.0.0",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-pngquant": "^9.0.0",
    "imagemin-svgo": "^10.0.0",
    "imagemin-webp": "^8.0.0",
    "rimraf": "^5.0.0",
    "lighthouse": "^11.0.0",
    "puppeteer": "^21.0.0",
    "compression": "^1.7.4",
    "express": "^4.18.0"
  },
  "dependencies": {
    "prismjs": "^1.29.0"
  },
  "keywords": [
    "blog",
    "static-site",
    "performance",
    "optimization",
    "ios",
    "swift",
    "javascript"
  ],
  "author": "bestswifter",
  "license": "CC"
}